{
  "name": "grand-i10-nios",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:prepare": "CI=1 npx expo prebuild --platform android --no-install",
    "build:android:apk": "npm run build:android:prepare && (cd android && export JAVA_HOME=\"${JAVA_HOME:-$(/usr/libexec/java_home -v 17)}\" ANDROID_HOME=\"${ANDROID_HOME:-$HOME/Library/Android/sdk}\" ANDROID_SDK_ROOT=\"${ANDROID_SDK_ROOT:-${ANDROID_HOME:-$HOME/Library/Android/sdk}}\"; export PATH=\"$JAVA_HOME/bin:$ANDROID_HOME/platform-tools:$PATH\"; ./gradlew assembleRelease)",
    "build:android:aab": "npm run build:android:prepare && (cd android && JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home PATH=/opt/homebrew/opt/openjdk@17/bin:$PATH ./gradlew bundleRelease)",
    "build:android:apk:cloud": "npx --yes eas-cli@latest build -p android --profile release-apk",
    "build:android:aab:cloud": "npx --yes eas-cli@latest build -p android --profile production",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.6.2",
    "dayjs": "^1.11.13",
    "expo": "~55.0.3",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-image": "~55.0.5",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "firebase": "^12.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.62.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
