{
  "expo": {
    "name": "Grand i10 Nios",
    "slug": "grand-i10-Nios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/g-i10-App-icon.png",
    "scheme": "grandi10nios",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/g-i10-App-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/g-i10-App-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "package": "com.sourav.grandi10Nios"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/g-i10-App-icon.png",
          "imageWidth": 144,
          "android": {
            "image": "./assets/images/g-i10-App-icon.png",
            "imageWidth": 144
          },
          "ios": {
            "image": "./assets/images/g-i10-App-icon.png",
            "imageWidth": 144
          }
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": {
                "light": "#000000",
                "dark": "#FFFFFF"
              },
              "colorControlActivated": {
                "light": "#000000",
                "dark": "#FFFFFF"
              },
              "colorControlHighlight": {
                "light": "#E6E6E6",
                "dark": "#2A2A2A"
              },
              "textColorPrimary": {
                "light": "#000000",
                "dark": "#FFFFFF"
              },
              "textColorSecondary": {
                "light": "#555555",
                "dark": "#BBBBBB"
              },
              "windowBackground": {
                "light": "#FFFFFF",
                "dark": "#000000"
              }
            },
            "timePicker": {
              "background": {
                "light": "#FFFFFF",
                "dark": "#000000"
              },
              "headerBackground": {
                "light": "#000000",
                "dark": "#FFFFFF"
              },
              "numbersBackgroundColor": {
                "light": "#F5F5F5",
                "dark": "#121212"
              },
              "numbersSelectorColor": {
                "light": "#000000",
                "dark": "#FFFFFF"
              },
              "numbersTextColor": {
                "light": "#000000",
                "dark": "#FFFFFF"
              }
            }
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Grand i10 Nios to use Face ID for secure login."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
